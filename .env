# PostgreSQL connection string.
# Matches the docker-compose.yml service in this repo.
DATABASE_URL="postgresql://voyage:voyage@localhost:5432/voyage?schema=public"

# Anthropic API key used to power AI itinerary generation.
# Get one at https://console.anthropic.com/
# If this is left unset, the app falls back to a built-in mock generator
# so you can run and demo the full flow without a key.
ANTHROPIC_API_KEY=""

# Model used for itinerary generation (optional; defaults to claude-opus-4-8).
ANTHROPIC_MODEL="claude-opus-4-8"

# Secret used to sign the admin/employee login session cookie. REQUIRED.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="d3c7de3e66cbd066de66f0669e98b204e3c878c4a9fb7d67705db81f85f109d8e3bf6d90ef60383f589719020bd24448"

# Set to "true" ONLY for local/HTTP deployments accessed over a plain
# http:// address other than localhost (e.g. from another device on your LAN
# at http://192.168.x.x:3000). It drops the "Secure" flag on the session
# cookie so login works without HTTPS. Leave unset in real production (HTTPS).
# AUTH_INSECURE_COOKIE="false"
